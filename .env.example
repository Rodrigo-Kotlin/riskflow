# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Set true to enable demo login button (local dev only)
VITE_ENABLE_DEMO_DATA=false


# ─── Cloudflare Pages ──────────────────────────────────────────────────────────
# Deploy: connect this repo to Cloudflare Pages, set build command to
#   npm run build
# and output directory to
#   dist
#
# Environment variables (Production):
#   VITE_SUPABASE_URL  : see above
#   VITE_SUPABASE_ANON_KEY : see above
#   VITE_ENABLE_DEMO_DATA : false
#
# CLI deploy (requires wrangler):
#   npx wrangler pages deploy dist --project-name=efetiva-riskflow
